generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -------------------- ENUMS --------------------

enum PapelUsuario {
  CLIENTE
  ADMINISTRADOR
}

enum StatusPedido {
  PENDENTE
  PROCESSANDO
  APROVADO
  RECUSADO
  REEMBOLSADO
}

enum TipoFormaPagamento {
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  BOLETO
}

enum NivelTutorial {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

enum TipoAnexo {
  IMAGEM
  VIDEO
}

enum ConversaStatus {
  TRIAGEM
  AGUARDANDO_ATENDENTE
  EM_ATENDIMENTO
  ENCERRADA
}

enum TipoMensagem {
  CLIENTE
  ATENDENTE
  BOT
  SISTEMA
}

// -------------------- USUÁRIO E PERFIL --------------------

model Usuario {
  id                       String       @id @default(uuid())
  nomeCompleto             String
  cpf                      String?      @unique
  email                    String       @unique
  senhaHash                String
  papel                    PapelUsuario @default(CLIENTE)
  fotoPerfilUrl            String?
  whatsapp                 String?
  telefone                 String?
  dataNascimento           DateTime?
  genero                   String?
  apelido                  String?
  profissao                String?
  contaPausada             Boolean      @default(false)
  emailVerificado          Boolean      @default(false)
  tokenVerificacaoEmail    String?
  tentativasLogin          Int          @default(0)
  bloqueadoAte             DateTime?
  tokenRecuperacaoHash     String?
  tokenRecuperacaoExpiraEm DateTime?
  criadoEm                 DateTime     @default(now())
  atualizadoEm             DateTime     @updatedAt

  endereco          Endereco?
  formasPagamento   FormaPagamento[]
  pedidos           Pedido[]
  comentarios       Comentario[]
  conversas         Conversa[]
  atendimentos      Conversa[]       @relation("AtendenteConversas")
  mensagensEnviadas Mensagem[]
  favoritos         FavoritoTutorial[]

  @@map("usuarios")
}

model Endereco {
  id          String  @id @default(uuid())
  cep         String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  usuario     Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId   String  @unique

  @@map("enderecos")
}

// Nunca guardamos número de cartão, CVV ou validade aqui — apenas o token
// que o gateway devolve depois da tokenização (exigência do padrão PCI-DSS).
model FormaPagamento {
  id                   String             @id @default(uuid())
  tipo                 TipoFormaPagamento
  tokenGateway         String?
  ultimosQuatroDigitos String?
  bandeira             String?
  principal            Boolean            @default(false)
  usuario              Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId            String
  criadoEm             DateTime           @default(now())

  @@map("formas_pagamento")
}

// -------------------- CATÁLOGO --------------------

model Categoria {
  id        String     @id @default(uuid())
  nome      String     @unique
  slug      String     @unique
  tutoriais Tutorial[]

  @@map("categorias")
}

model Tutorial {
  id                  String        @id @default(uuid())
  titulo              String
  slug                String        @unique
  descricaoCurta      String
  descricaoCompleta   String
  preco               Decimal       @db.Decimal(10, 2)
  precoPromocional    Decimal?      @db.Decimal(10, 2)
  imagemCapaUrl       String
  videoPreviaUrl      String?
  cupomDesconto       String?
  destaquePromocional Boolean       @default(false)
  bombando            Boolean       @default(false)
  fotosGaleria        String[]      @default([])
  cidade              String?
  estado              String?
  distanciaKm         Int?
  nivel               NivelTutorial @default(INICIANTE)
  ativo               Boolean       @default(true)
  categoria           Categoria     @relation(fields: [categoriaId], references: [id])
  categoriaId         String
  modulos             Modulo[]
  itensPedido         ItemPedido[]
  comentarios         Comentario[]
  favoritos           FavoritoTutorial[]
  criadoEm            DateTime      @default(now())
  atualizadoEm        DateTime      @updatedAt

  @@index([categoriaId])
  @@map("tutoriais")
}

model Modulo {
  id             String   @id @default(uuid())
  titulo         String
  ordem          Int
  videoUrl       String
  duracaoMinutos Int
  gratuito       Boolean  @default(false)
  tutorial       Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)
  tutorialId     String

  @@map("modulos")
}

model FavoritoTutorial {
  id         String   @id @default(uuid())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String
  tutorial  Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)
  tutorialId String
  criadoEm  DateTime @default(now())

  @@unique([usuarioId, tutorialId])
  @@index([tutorialId])
  @@map("favoritos_tutoriais")
}

// -------------------- PEDIDOS E PAGAMENTO --------------------

model Pedido {
  id                 String       @id @default(uuid())
  usuario            Usuario      @relation(fields: [usuarioId], references: [id])
  usuarioId          String
  status             StatusPedido @default(PENDENTE)
  valorTotal         Decimal      @db.Decimal(10, 2)
  idTransacaoGateway String?
  comprovanteUrl     String?
  itens              ItemPedido[]
  criadoEm           DateTime     @default(now())
  atualizadoEm       DateTime     @updatedAt

  @@index([usuarioId])
  @@map("pedidos")
}

model ItemPedido {
  id            String   @id @default(uuid())
  pedido        Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId      String
  tutorial      Tutorial @relation(fields: [tutorialId], references: [id])
  tutorialId    String
  precoUnitario Decimal  @db.Decimal(10, 2)

  @@map("itens_pedido")
}

// -------------------- COMENTÁRIOS E AVALIAÇÕES --------------------

model Comentario {
  id         String            @id @default(uuid())
  nota       Int
  texto      String
  usuario    Usuario           @relation(fields: [usuarioId], references: [id])
  usuarioId  String
  tutorial   Tutorial          @relation(fields: [tutorialId], references: [id], onDelete: Cascade)
  tutorialId String
  anexos     AnexoComentario[]
  criadoEm   DateTime          @default(now())
  editadoEm  DateTime          @updatedAt

  @@unique([usuarioId, tutorialId])
  @@map("comentarios")
}

model AnexoComentario {
  id           String     @id @default(uuid())
  tipo         TipoAnexo
  url          String
  comentario   Comentario @relation(fields: [comentarioId], references: [id], onDelete: Cascade)
  comentarioId String

  @@map("anexos_comentario")
}

// -------------------- CHAT --------------------

model Conversa {
  id                       String         @id @default(uuid())
  protocolo                String         @unique @default(uuid())
  status                   ConversaStatus @default(TRIAGEM)
  assunto                  String?
  usuario                  Usuario        @relation(fields: [usuarioId], references: [id])
  usuarioId                String
  atendente                Usuario?       @relation("AtendenteConversas", fields: [atendenteId], references: [id])
  atendenteId              String?
  clienteAguardandoDesde   DateTime?
  atendimentoIniciadoEm    DateTime?
  ultimaInteracaoClienteEm DateTime?
  avisoInatividadeEm       DateTime?
  encerradoEm              DateTime?
  encerradoPor             String?
  avaliacaoNota            Int?
  avaliacaoTexto           String?
  avaliacaoEnviadaEm       DateTime?
  mensagens                Mensagem[]
  criadoEm                 DateTime       @default(now())
  atualizadoEm             DateTime       @updatedAt

  @@index([usuarioId])
  @@index([atendenteId])
  @@index([status])
  @@map("conversas")
}

model Mensagem {
  id          String          @id @default(uuid())
  texto       String?
  tipo        TipoMensagem    @default(CLIENTE)
  conversa    Conversa        @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  conversaId  String
  remetente   Usuario?        @relation(fields: [remetenteId], references: [id])
  remetenteId String?
  lida        Boolean         @default(false)
  anexos      AnexoMensagem[]
  criadoEm    DateTime        @default(now())

  @@index([conversaId])
  @@index([remetenteId])
  @@map("mensagens")
}

model AnexoMensagem {
  id         String    @id @default(uuid())
  tipo       TipoAnexo
  url        String
  mensagem   Mensagem  @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  mensagemId String

  @@map("anexos_mensagem")
}

// -------------------- CUPONS --------------------

model Cupom {
  id                 String   @id @default(uuid())
  codigo             String   @unique
  descontoPercentual Int
  ativo              Boolean  @default(true)
  validoAte          DateTime
  criadoEm           DateTime @default(now())

  @@map("cupons")
}

// -------------------- ANÚNCIOS --------------------

model Anuncio {
  id        String   @id @default(uuid())
  titulo    String
  imagemUrl String
  linkUrl   String
  corFundo  String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  @@map("anuncios")
}

// -------------------- CONFIGURACOES --------------------

model ConfiguracaoAvisoTopo {
  id               String    @id @default(uuid())
  titulo           String
  mensagem         String
  linkTexto        String?
  linkUrl          String?
  corFundo         String    @default("#b9923d")
  corTexto         String    @default("#ffffff")
  ativo            Boolean   @default(false)
  inicioEm         DateTime
  fimEm            DateTime
  desativadoEm     DateTime?
  desativadoMotivo String?
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  @@index([ativo, inicioEm, fimEm])
  @@map("configuracoes_aviso_topo")
}
